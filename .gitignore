# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.pytest_cache/

# Notebooks
.ipynb_checkpoints/

# Virtual environments
.venv
*.jpg

# Pipeline outputs (do not commit binary artifacts)
results/
results_/
*.h5
*.mp4
*.png

# Scratch / working files (not for version control)
scratch/

# ...except the committed example recording (overrides the *.mp4 rule above)
!examples/data/*.mp4